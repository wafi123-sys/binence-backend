{
  "name": "binence",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server/server.ts",
    "dev:next": "next dev",
    "build": "next build",
    "build:android": "next build && npx cap sync android",
    "start": "tsx server/server.ts",
    "lint": "eslint",
    "tunnel": "npx cloudflared tunnel --url http://localhost:3001",
    "dev:all": "concurrently \"npm run dev\" \"npm run tunnel\"",
    "backtest": "npx ts-node -e \"require('ts-node').register({project:'tsconfig.json'}); require('./server/backtest/run-backtest')\"",
    "backtest:btc": "npx tsx server/backtest/run-backtest.ts btcusdt all 10000",
    "backtest:eth": "npx tsx server/backtest/run-backtest.ts ethusdt all 10000"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "apexcharts": "^5.15.0",
    "dotenv": "^17.4.2",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-dom": "19.2.4",
    "uuid": "^14.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
